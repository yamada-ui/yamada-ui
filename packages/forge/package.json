{
  "name": "@yamada-ui/forge",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "The forge for Yamada UI projects",
  "scripts": {
    "clean": "rimraf node_modules trace .eslintcache",
    "typecheck": "tsc --noEmit",
    "typetrace": "tsc --noEmit --generateTrace ./trace --incremental false",
    "typeanalyze": "npx analyze-trace ./trace --expandTypes=false",
    "lint": "eslint . --max-warnings=0 --cache",
    "format": "prettier . --ignore-path ../../.prettierignore --check --cache",
    "quality": "pnpm format && pnpm lint && pnpm typecheck",
    "issue:create": "tsx src/issue/create",
    "issue:codecov": "tsx src/issue/codecov",
    "issue:a11y": "tsx src/issue/a11y",
    "issue:template": "tsx src/issue/template"
  },
  "dependencies": {
    "@changesets/types": "^6.1.0",
    "@changesets/write": "^0.4.0",
    "@pnpm/lockfile.fs": "^1001.1.32",
    "@pnpm/workspace.workspace-manifest-reader": "^1000.2.5",
    "@yamada-ui/utils": "workspace:*",
    "@yamada-ui/workspace": "workspace:*",
    "strip-ansi": "^7.2.0"
  }
}
