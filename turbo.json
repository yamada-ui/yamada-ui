{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "futureFlags": { "affectedUsingTaskInputs": true },
  "tasks": {
    "//#transit": { "dependsOn": ["^transit"] },
    "transit": {
      "dependsOn": ["^transit"],
      "inputs": [
        "package.json",
        "src/**/*.{ts,tsx,mts}",
        "!src/**/*.{test,stories}.{ts,tsx,mts}"
      ]
    },
    "transit:test": {
      "dependsOn": ["^transit:test"],
      "inputs": ["src/vitest/**", "package.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "package.json",
        "{src,@types}/**/*.{ts,tsx,mts}",
        "!src/**/*.{test,stories}.{ts,tsx,mts}"
      ],
      "outputs": ["dist/**"]
    },
    "build:content": {
      "dependsOn": ["transit"],
      "outputs": [".velite/**", "data/doc-map.*.json"]
    },
    "test": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:jsdom": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!**/*.test.{browser,chromium,firefox,webkit}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:chromium": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{firefox,webkit}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:firefox": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{chromium,webkit}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:webkit": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{chromium,firefox}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:coverage": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ],
      "outputs": ["coverage/**"]
    },
    "test:coverage:jsdom": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{browser,chromium,firefox,webkit}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ],
      "outputs": ["coverage/jsdom/**"]
    },
    "test:coverage:chromium": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{firefox,webkit}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ],
      "outputs": ["coverage/chromium/**"]
    },
    "test:coverage:firefox": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{chromium,webkit}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ],
      "outputs": ["coverage/firefox/**"]
    },
    "test:coverage:webkit": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.{test,stories}.{ts,tsx,mts}",
        "!**/*.test.{chromium,firefox}.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ],
      "outputs": ["coverage/webkit/**"]
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "inputs": [
        "package.json",
        "tsconfig.json",
        "src/**/*.{ts,tsx,mts}",
        "!src/**/*.{test,stories}.{ts,tsx,mts}"
      ]
    },
    "lint": {
      "dependsOn": ["transit"],
      "inputs": [
        "package.json",
        "tsconfig.json",
        "src/**/*.{ts,tsx,mts}",
        "!src/**/*.{test,stories}.{ts,tsx,mts}"
      ]
    }
  },
  "globalDependencies": ["tsconfig.json"]
}
