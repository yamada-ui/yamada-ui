{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "tasks": {
    "//#transit": { "dependsOn": ["^transit"] },
    "transit": { "dependsOn": ["^transit"] },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:content": {
      "dependsOn": ["transit"],
      "outputs": [".velite/**", "data/doc-map.*.json"]
    },
    "test": {
      "dependsOn": ["transit"]
    },
    "test:coverage": {
      "dependsOn": ["transit"],
      "outputs": ["coverage/**"]
    },
    "test:chromium": {
      "dependsOn": ["transit"]
    },
    "test:firefox": {
      "dependsOn": ["transit"]
    },
    "test:webkit": {
      "dependsOn": ["transit"]
    },
    "typecheck": {
      "dependsOn": ["transit"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "format": {
      "dependsOn": ["transit"]
    }
  },
  "globalDependencies": ["tsconfig.json"]
}
