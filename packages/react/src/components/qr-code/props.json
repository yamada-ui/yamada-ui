        "required": false
      },
      "maxVersion": {
        "type": "number",
        "defaultValue": "40",
        "description": "The maximum version of the QR code (1-40).",
        "required": false
      },
      "minVersion": {
        "type": "number",
        "defaultValue": "1",
        "description": "The minimum version of the QR code (1-40).",
        "required": false
      },
      "onEncoded": {
        "type": "(qr: QrCodeGenerateResult) => void",
