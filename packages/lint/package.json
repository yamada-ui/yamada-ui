{
  "name": "@yamada-ui/lint",
  "type": "module",
  "version": "0.0.0",
  "description": "The official ESLint plugin for Yamada UI projects",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "yamada ui",
    "yamada",
    "ui"
  ],
  "author": "Hirotomo Yamada <hirotomo.yamada@avap.co.jp>",
  "license": "MIT",
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://yamada-ui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/yamada-ui/yamada-ui",
    "directory": "packages/lint"
  },
  "bugs": {
    "url": "https://github.com/yamada-ui/yamada-ui/issues"
  },
  "scripts": {
    "clean": "rimraf node_modules dist trace coverage .turbo .eslintcache",
    "build": "tsdown",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:dev": "vitest --watch --ui",
    "typecheck": "tsc --noEmit",
    "typetrace": "tsc --noEmit --generateTrace ./trace --incremental false",
    "typeanalyze": "npx analyze-trace ./trace --expandTypes=false",
    "lint": "eslint . --max-warnings=0 --cache",
    "format": "prettier . --ignore-path ../../.prettierignore --check --cache",
    "quality": "pnpm format && pnpm lint && pnpm typecheck && pnpm test",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.58.0"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "8.58.0",
    "@yamada-ui/react": "workspace:*",
    "@yamada-ui/workspace": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "@yamada-ui/react": "workspace:*",
    "eslint": ">=9"
  },
  "clean-package": "./clean-package.config.json"
}
