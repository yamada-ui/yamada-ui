{
  "name": "@yamada-ui/cli",
  "type": "module",
  "version": "2.1.5",
  "description": "The official CLI for Yamada UI projects",
  "keywords": [
    "theme",
    "theming",
    "typings",
    "generator",
    "yamada ui",
    "yamada",
    "ui mode",
    "ui"
  ],
  "author": "Hirotomo Yamada <hirotomo.yamada@avap.co.jp>",
  "license": "MIT",
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://yamada-ui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/yamada-ui/yamada-ui",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/yamada-ui/yamada-ui/issues"
  },
  "scripts": {
    "clean": "rimraf node_modules dist trace coverage .turbo .eslintcache",
    "dev": "tsx src/index.ts",
    "build": "tsdown",
    "test": "vitest",
    "test:dev": "vitest --watch --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": " tsc --noEmit",
    "typetrace": "tsc --noEmit --generateTrace ./trace --incremental false",
    "typeanalyze": "npx analyze-trace ./trace --expandTypes=false",
    "lint": "eslint . --max-warnings=0 --cache",
    "format": "pnpm -w format packages/cli",
    "quality": "pnpm format && pnpm lint && pnpm typecheck && pnpm test",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@yamada-ui/utils": "workspace:*",
    "boxen": "^8.0.1",
    "cli-check-node": "^1.3.4",
    "commander": "catalog:",
    "diff": "^8.0.4",
    "esbuild": "^0.28.0",
    "eslint": "catalog:",
    "https-proxy-agent": "^9.0.0",
    "listr2": "^10.2.1",
    "node-eval": "^2.0.0",
    "node-fetch": "^3.3.2",
    "ora": "catalog:",
    "picocolors": "catalog:",
    "prettier": "catalog:",
    "prompts": "^2.4.2",
    "rimraf": "catalog:",
    "semver": "^7.7.4",
    "sucrase": "^3.35.1",
    "validate-npm-package-name": "^7.0.2",
    "yamljs": "catalog:"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "@types/update-notifier": "6.0.8",
    "@types/validate-npm-package-name": "^4.0.2",
    "@types/yamljs": "catalog:",
    "@yamada-ui/workspace": "workspace:*",
    "update-notifier": "^7.3.1"
  },
  "clean-package": "./clean-package.config.json"
}
