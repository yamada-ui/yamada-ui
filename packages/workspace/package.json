{
  "name": "@yamada-ui/workspace",
  "version": "1.0.0",
  "private": true,
  "description": "The workspace for Yamada UI projects",
  "type": "module",
  "exports": {
    "./eslint": "./src/eslint/index.ts",
    "./oxfmt": "./src/oxfmt/index.ts",
    "./oxfmt/*": "./src/oxfmt/*.js",
    "./prettier": "./src/prettier/index.ts",
    "./prettier/*": "./src/prettier/*.js",
    "./typescript/*": "./src/typescript/*",
    "./vitest": "./src/vitest/index.ts",
    "./vitest/*": "./src/vitest/*.ts",
    "./octokit": "./src/octokit/index.ts",
    "./codecov": "./src/codecov/index.ts",
    "./discord": "./src/discord/index.ts"
  },
  "scripts": {
    "clean": "rimraf node_modules trace .eslintcache",
    "typecheck": "tsc --noEmit",
    "typetrace": "tsc --noEmit --generateTrace ./trace --incremental false",
    "typeanalyze": "npx analyze-trace ./trace --expandTypes=false",
    "lint": "eslint . --max-warnings=0 --cache",
    "format": "pnpm -w format packages/workspace",
    "quality": "pnpm -w format packages/workspace && pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@cspell/eslint-plugin": "^9.8.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/config-helpers": "^0.5.3",
    "@eslint/js": "^9.39.4",
    "@limegrass/eslint-plugin-import-alias": "^1.6.1",
    "@next/eslint-plugin-next": "^16.2.2",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@testing-library/jest-dom": "catalog:",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@typescript-eslint/parser": "catalog:",
    "@typescript-eslint/utils": "^8.58.0",
    "@vitest/eslint-plugin": "^1.6.14",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-replace": "^1.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unused-imports": "catalog:",
    "globals": "^17.4.0",
    "oxfmt": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.0",
    "vitest": "catalog:",
    "vitest-axe": "catalog:"
  }
}
