{
  "name": "@yamada-ui/react",
  "type": "module",
  "version": "2.2.0",
  "description": "React UI components of the Yamada, by the Yamada, for the Yamada built with React and Emotion",
  "keywords": [
    "yamada",
    "yamada-ui",
    "react",
    "ui",
    "design-system",
    "react-components",
    "uikit",
    "accessible",
    "components",
    "emotion",
    "library",
    "design-system"
  ],
  "author": "Hirotomo Yamada <hirotomo.yamada@avap.co.jp>",
  "license": "MIT",
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://yamada-ui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/yamada-ui/yamada-ui",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/yamada-ui/yamada-ui/issues"
  },
  "imports": {
    "#storybook": "./storybook/index.ts",
    "#test": "./test/index.ts",
    "#test/browser": "./test/browser/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./utils": "./src/utils/index.ts",
    "./theme": "./src/theme/index.ts",
    "./providers/*": "./src/providers/*/index.ts",
    "./components/*": "./src/components/*/index.ts",
    "./hooks/*": "./src/hooks/*/index.ts"
  },
  "scripts": {
    "clean": "rimraf node_modules dist trace coverage storybook-static .turbo .vitest-attachments __screenshots__",
    "prebuild": "pnpm gen:tokens",
    "build": "tsdown",
    "storybook": "storybook dev -p 6006 -c storybook",
    "storybook:serve": "npx http-server ./storybook-static",
    "storybook:build": "storybook build -c storybook",
    "test": "vitest",
    "test:jsdom": "vitest --project=jsdom",
    "test:browser": "vitest --project=browser:chromium --project=browser:firefox --project=browser:webkit",
    "test:chromium": "vitest --project=browser:chromium",
    "test:webkit": "vitest --project=browser:webkit",
    "test:firefox": "vitest --project=browser:firefox",
    "test:dev": "vitest --watch --ui",
    "test:dev:jsdom": "vitest --watch --ui --project=jsdom",
    "test:dev:browser": "vitest --watch --ui --project=browser:chromium --project=browser:firefox --project=browser:webkit",
    "test:dev:chromium": "vitest --watch --ui --project=browser:chromium",
    "test:dev:webkit": "vitest --watch --ui --project=browser:webkit",
    "test:dev:firefox": "vitest --watch --ui --project=browser:firefox",
    "test:coverage": "vitest run --coverage",
    "test:coverage:jsdom": "vitest run --project=jsdom --coverage --coverage.reportsDirectory=coverage/jsdom",
    "test:coverage:chromium": "vitest run --project=browser:chromium --coverage --coverage.provider=istanbul --coverage.reportsDirectory=coverage/chromium",
    "test:coverage:webkit": "vitest run --project=browser:webkit --coverage --coverage.provider=istanbul --coverage.reportsDirectory=coverage/webkit",
    "test:coverage:firefox": "vitest run --project=browser:firefox --coverage --coverage.provider=istanbul --coverage.reportsDirectory=coverage/firefox",
    "test:a11y": "storybook dev --ci -p 6006 -c storybook & wait-on http://localhost:6006 && test-storybook -c storybook --maxWorkers=8 --json --outputFile report.json",
    "typecheck": "tsgo",
    "typetrace": "tsgo --generateTrace ./trace --incremental false",
    "typeanalyze": "npx analyze-trace ./trace --expandTypes=false",
    "lint": "oxlint . --max-warnings=0",
    "format": "pnpm -w format packages/react",
    "quality": "pnpm format && pnpm lint && pnpm typecheck && pnpm test",
    "gen:styles": "tsx scripts/generate/styles",
    "gen:icons": "tsx scripts/generate/icons",
    "gen:props": "tsx scripts/generate/props",
    "gen:registries": "tsx scripts/generate/registries",
    "gen:tokens": "pnpm -C ../cli dev tokens src/theme/index.ts --internal -fl -o src/core/generated-theme-tokens.types.ts",
    "notification:release": "tsx scripts/notification/release",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "catalog:",
    "@emotion/serialize": "^1.3.3",
    "@emotion/sheet": "^1.4.0",
    "@emotion/styled": "^11.14.1",
    "@emotion/use-insertion-effect-with-fallbacks": "^1.2.0",
    "@emotion/utils": "^1.4.2",
    "@floating-ui/react-dom": "^2.1.8",
    "@tanstack/react-table": "^8.21.3",
    "@yamada-ui/utils": "workspace:*",
    "copy-to-clipboard": "3.3.3",
    "csstype": "^3.2.3",
    "dayjs": "catalog:",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "file-selector": "^2.1.2",
    "framesync": "6.1.2",
    "intl-messageformat": "^11.2.2",
    "lucide-react": "1.14.0",
    "motion": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-dropzone": "^15.0.0",
    "react-fast-compare": "^3.2.2",
    "react-focus-lock": "^2.13.7",
    "react-remove-scroll": "^2.7.2",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.1",
    "scroll-into-view-if-needed": "catalog:",
    "sonner": "^2.0.7",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@faker-js/faker": "catalog:",
    "@lucide/lab": "catalog:",
    "@mdn/browser-compat-data": "7.3.14",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__traverse": "^7.28.0",
    "@types/jsdom": "^28.0.1",
    "@types/yamljs": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@yamada-ui/workspace": "workspace:*",
    "axe-playwright": "^2.2.2",
    "jsdom": "^29.1.1",
    "playwright": "catalog:",
    "react-hook-form": "catalog:",
    "react-icons": "catalog:",
    "use-mask-input": "^3.9.0",
    "vitest-axe": "catalog:",
    "vitest-browser-react": "2.2.0",
    "web-features": "3.26.0",
    "yamljs": "catalog:"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "motion": ">=12",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "clean-package": "./clean-package.config.json"
}
