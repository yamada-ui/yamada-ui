{
  "name": "@playgrounds/react-router-framework",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf node_modules .react-router .eslintcache",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint . --max-warnings=0 --cache",
    "format": "prettier . --ignore-path ../../../.prettierignore --check --cache",
    "yamada-cli": "pnpm -C ../../../packages/cli dev"
  },
  "dependencies": {
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@yamada-ui/react": "workspace:*",
    "isbot": "^5.1.37",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.0",
    "@yamada-ui/workspace": "workspace:*",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  }
}
