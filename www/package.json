{
  "name": "www",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=24.14"
  },
  "imports": {
    "#velite": "./.velite"
  },
  "scripts": {
    "clean": "rimraf .next .velite .eslintcache tsconfig.tsbuildinfo node_modules",
    "dev:content": "velite --watch",
    "dev:next": "next dev",
    "dev": "run-p dev:*",
    "build:content": "NODE_ENV=production velite --clean",
    "build:next": "next build",
    "build": "run-s build:*",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0 --cache",
    "format": "prettier . --ignore-path ../.prettierignore --check --cache",
    "quality": "pnpm format && pnpm lint && pnpm typecheck",
    "gen:icons": "tsx scripts/generate/icons",
    "gen:docs": "tsx scripts/generate/docs",
    "gen:theme": "tsx scripts/generate/theme",
    "gen:conditions": "tsx scripts/generate/conditions",
    "gen:changelog": "tsx scripts/generate/changelog",
    "gen:contributors": "tsx scripts/generate/contributors",
    "gen:relations": "tsx scripts/generate/relations"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "catalog:",
    "@emotion/weak-memoize": "^0.4.0",
    "@faker-js/faker": "catalog:",
    "@lucide/lab": "catalog:",
    "@stackblitz/sdk": "^1.11.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@yamada-ui/react": "workspace:*",
    "match-sorter": "^8.2.0",
    "motion": "catalog:",
    "next": "catalog:",
    "next-intl": "^4.8.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "catalog:",
    "react-icons": "catalog:",
    "scroll-into-view-if-needed": "catalog:",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@shikijs/rehype": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/parser": "catalog:",
    "@yamada-ui/cli": "workspace:*",
    "@yamada-ui/utils": "workspace:*",
    "@yamada-ui/workspace": "workspace:*",
    "baseline-browser-mapping": "^2.10.12",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-heading-rank": "^3.0.0",
    "hast-util-to-string": "^3.0.1",
    "hastscript": "^9.0.1",
    "npm-run-all": "^4.1.5",
    "ora": "catalog:",
    "picocolors": "catalog:",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sucrase": "catalog:",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "velite": "^0.3.1"
  }
}
