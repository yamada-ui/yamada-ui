{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "futureFlags": { "affectedUsingTaskInputs": true },
  "tasks": {
    "//#transit": { "dependsOn": ["^transit"] },
    "transit": { "dependsOn": ["^transit"] },
    "transit:test": {
      "dependsOn": ["^transit:test"],
      "inputs": ["src/vitest/**", "package.json"]
    },
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "build:content": {
      "dependsOn": ["transit"],
      "outputs": [".velite/**", "data/doc-map.*.json"]
    },
    "test": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:coverage": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ],
      "outputs": ["coverage/**"]
    },
    "test:chromium": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:firefox": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "test:webkit": {
      "dependsOn": ["transit:test"],
      "inputs": [
        "package.json",
        "**/*.{ts,tsx,mts}",
        "!**/*.stories.{ts,tsx,mts}",
        "!{oxlint,tsdown}.config.ts",
        "!{scripts,storybook,@types}/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "inputs": ["**/*.{ts,tsx,mts}", "package.json", "tsconfig.json"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "inputs": ["**/*.{ts,tsx,mts}", "package.json", "tsconfig.json"]
    }
  },
  "globalDependencies": ["tsconfig.json"]
}
